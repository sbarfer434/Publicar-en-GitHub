            &lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"2026040921071932405L","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"&lt;p&gt;Una vez dentro, tienes que crear un nuevo repositorio (Repositories) donde vamos a subir tu proyecto:&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/2026040921071932405L/mceclip3.png\" /&gt;&lt;/p&gt;","textFeedbackInput":"Mostrar retroalimentación","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure><odePagStructure><odePageId>20260409201511IFJNRU</odePageId><odeBlockId>20260409201511WKQIIC</odeBlockId><blockName/><iconName/><odePagStructureOrder>2</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260409201511IFJNRU</odePageId><odeBlockId>20260409201511WKQIIC</odeBlockId><odeIdeviceId>20260409210828301JTA</odeIdeviceId><odeIdeviceTypeName>text</odeIdeviceTypeName><htmlView>&lt;div class="exe-text-template"&gt;&lt;div class="textIdeviceContent"&gt;
            &lt;div class="exe-text-activity"&gt;
                &lt;div&gt;&lt;p&gt;Para crear tu repositorio pulsa en "New Repository"&lt;/p&gt;
&lt;p&gt;&lt;img src="{{context_path}}/20260409210828301JTA/mceclip4.png"&gt;&lt;/p&gt;
&lt;p&gt;Ahora elije el nombre de tu proyecto y una breve descripción:&lt;/p&gt;
&lt;p&gt;&lt;img src="{{context_path}}/20260409210828301JTA/mceclip5.png"&gt;&lt;/p&gt;
&lt;p&gt;Abajo a la derecha, pulsa &lt;img src="{{context_path}}/20260409210828301JTA/mceclip6.png"&gt;, te lleva a esta pantalla, donde pulsamos el enlace &lt;img src="{{context_path}}/20260409210828301JTA/mceclip8.png"&gt;:&lt;/p&gt;
&lt;p&gt;&lt;img src="{{context_path}}/20260409210828301JTA/mceclip7.png"&gt;&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p class="clearfix"&gt;&lt;/p&gt;&lt;/div&gt;
            &lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260409210828301JTA","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"&lt;p&gt;Para crear tu repositorio pulsa en \"New Repository\"&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip4.png\" /&gt;&lt;/p&gt;\n&lt;p&gt;Ahora elije el nombre de tu proyecto y una breve descripción:&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip5.png\" /&gt;&lt;/p&gt;\n&lt;p&gt;Abajo a la derecha, pulsa &lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip6.png\" /&gt;, te lleva a esta pantalla, donde pulsamos el enlace &lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip8.png\" /&gt;:&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip7.png\" /&gt;&lt;/p&gt;\n&lt;p&gt;&lt;br /&gt;&lt;/p&gt;","textFeedbackInput":"Mostrar retroalimentación","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure></odePagStructures></odeNavStructure><odeNavStructure><odePageId>20260409201511YCTDEW</odePageId><odeParentPageId/><pageName>Subir archivos</pageName><odeNavStructureOrder>4</odeNavStructureOrder><odeNavStructureProperties><odeNavStructureProperty><key>titleNode</key><value>Subir archivos</value></odeNavStructureProperty><odeNavStructureProperty><key>titleHtml</key><value/></odeNavStructureProperty><odeNavStructureProperty><key>editableInPage</key><value>false</value></odeNavStructureProperty><odeNavStructureProperty><key>titlePage</key><value>Subir archivos</value></odeNavStructureProperty><odeNavStructureProperty><key>visibility</key><value>true</value></odeNavStructureProperty><odeNavStructureProperty><key>description</key><value/></odeNavStructureProperty></odeNavStructureProperties><odePagStructures><odePagStructure><odePageId>20260409201511YCTDEW</odePageId><odeBlockId>20260409201511FTIISK</odeBlockId><blockName/><iconName/><odePagStructureOrder>1</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260409201511YCTDEW</odePageId><odeBlockId>20260409201511FTIISK</odeBlockId><odeIdeviceId>20260409211622222V6M</odeIdeviceId><odeIdeviceTypeName>text</odeIdeviceTypeName><htmlView>&lt;div class="exe-text-template"&gt;&lt;div class="textIdeviceContent"&gt;
            &lt;div class="exe-text-activity"&gt;
                &lt;div&gt;&lt;p&gt;Ahora tenemos que subir nuestros archivos, para ello tienes que localizar la carpeta que exportaste desde eXeLearning desde siguiente pantalla pulsando &lt;img src="{{context_path}}/20260409211622222V6M/mceclip12.png"&gt;:&lt;/p&gt;
&lt;p&gt;&lt;img src="{{context_path}}/20260409211622222V6M/mceclip11.png"&gt;&lt;/p&gt;
&lt;p&gt;Muy importante, hay que subir los ficheros, nunca las carpetas, así que una vez localizada la carpeta entramos dentro y seleccionamos todos los archivos. Tienes que ir entrando dentro de cada carpeta y seleccionar todos los archivos, observa que el fichero&lt;strong&gt; index.html&lt;/strong&gt; esté subido. En GitHub se verá así:&lt;/p&gt;
&lt;p&gt;&lt;img src="{{context_path}}/20260409211622222V6M/mceclip15.png"&gt;&lt;/p&gt;
&lt;p&gt;&lt;/p&gt;
&lt;p&gt;Ahora hay que pulsar &lt;img src="{{context_path}}/20260409211622222V6M/mceclip16.png"&gt; al final de la pantalla.&lt;/p&gt;&lt;p class="clearfix"&gt;&lt;/p&gt;&lt;/div&gt;
            &lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260409211622222V6M","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"&lt;p&gt;Ahora tenemos que subir nuestros archivos, para ello tienes que localizar la carpeta que exportaste desde eXeLearning desde siguiente pantalla pulsando &lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip12.png\" /&gt;:&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip11.png\" /&gt;&lt;/p&gt;\n&lt;p&gt;Muy importante, hay que subir los ficheros, nunca las carpetas, así que una vez localizada la carpeta entramos dentro y seleccionamos todos los archivos. Tienes que ir entrando dentro de cada carpeta y seleccionar todos los archivos, observa que el fichero&lt;strong&gt; index.html&lt;/strong&gt; esté subido. En GitHub se verá así:&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip15.png\" /&gt;&lt;/p&gt;\n&lt;p&gt;&lt;/p&gt;\n&lt;p&gt;Ahora hay que pulsar &lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip16.png\" /&gt; al final de la pantalla.&lt;/p&gt;","textFeedbackInput":"Mostrar retroalimentación","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure></odePagStructures></odeNavStructure><odeNavStructure><odePageId>20260409201511GWXQLL</odePageId><odeParentPageId/><pageName>Preparar el enlace publicado de tu proyecto</pageName><odeNavStructureOrder>5</odeNavStructureOr