&lt;p&gt;&lt;img src="{{context_path}}/20260409210828301JTA/mceclip5.png"&gt;&lt;/p&gt;
&lt;p style="text-align: justify; color: blue;"&gt;&lt;strong&gt;Abajo a la derecha, pulsa &lt;img src="{{context_path}}/20260409210828301JTA/mceclip6.png"&gt;, te lleva a esta pantalla, donde pulsamos el enlace &lt;img src="{{context_path}}/20260409210828301JTA/mceclip8.png"&gt;:&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src="{{context_path}}/20260409210828301JTA/mceclip7.png"&gt;&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p class="clearfix"&gt;&lt;/p&gt;&lt;/div&gt;
            &lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260409210828301JTA","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;strong&gt;Para crear tu repositorio pulsa en \"New Repository\"&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip4.png\" /&gt;&lt;/p&gt;\n&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;strong&gt;Ahora elije el nombre de tu proyecto y una breve descripción:&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip5.png\" /&gt;&lt;/p&gt;\n&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;strong&gt;Abajo a la derecha, pulsa &lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip6.png\" /&gt;, te lleva a esta pantalla, donde pulsamos el enlace &lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip8.png\" /&gt;:&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409210828301JTA/mceclip7.png\" /&gt;&lt;/p&gt;\n&lt;p&gt;&lt;br /&gt;&lt;/p&gt;","textFeedbackInput":"Mostrar retroalimentación","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure></odePagStructures></odeNavStructure><odeNavStructure><odePageId>20260410054007KGOHQF</odePageId><odeParentPageId/><pageName>Subir archivos</pageName><odeNavStructureOrder>4</odeNavStructureOrder><odeNavStructureProperties><odeNavStructureProperty><key>titleNode</key><value>Subir archivos</value></odeNavStructureProperty><odeNavStructureProperty><key>titleHtml</key><value/></odeNavStructureProperty><odeNavStructureProperty><key>editableInPage</key><value>false</value></odeNavStructureProperty><odeNavStructureProperty><key>titlePage</key><value>Subir archivos</value></odeNavStructureProperty><odeNavStructureProperty><key>visibility</key><value>true</value></odeNavStructureProperty><odeNavStructureProperty><key>description</key><value/></odeNavStructureProperty></odeNavStructureProperties><odePagStructures><odePagStructure><odePageId>20260410054007KGOHQF</odePageId><odeBlockId>20260410054007CHZFBI</odeBlockId><blockName/><iconName/><odePagStructureOrder>1</odePagStructureOrder><odePagStructureProperties><odePagStructureProperty><key>visibility</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>teacherOnly</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>allowToggle</key><value>true</value></odePagStructureProperty><odePagStructureProperty><key>minimized</key><value>false</value></odePagStructureProperty><odePagStructureProperty><key>identifier</key><value/></odePagStructureProperty><odePagStructureProperty><key>cssClass</key><value/></odePagStructureProperty></odePagStructureProperties><odeComponents><odeComponent><odePageId>20260410054007KGOHQF</odePageId><odeBlockId>20260410054007CHZFBI</odeBlockId><odeIdeviceId>20260409211622222V6M</odeIdeviceId><odeIdeviceTypeName>text</odeIdeviceTypeName><htmlView>&lt;div class="exe-text-template"&gt;&lt;div class="textIdeviceContent"&gt;
            &lt;div class="exe-text-activity"&gt;
                &lt;div&gt;&lt;p style="text-align: justify; color: blue;"&gt;&lt;strong&gt;Ahora tenemos que subir nuestros archivos, para ello tienes que localizar la carpeta que exportaste desde eXeLearning desde siguiente pantalla:&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src="{{context_path}}/20260409211622222V6M/mceclip11.png" style="display: block; margin-left: auto; margin-right: auto;"&gt;&lt;/p&gt;
&lt;p style="text-align: justify; color: blue;"&gt;&lt;strong&gt;Muy importante, al subir hay que mantener la estructura de los ficheros, te recomiendo abrir el explorador de archivos de tu equipo y arrastrar archivos y carpetas directamente.&lt;/strong&gt;&lt;/p&gt;
&lt;p style="text-align: justify; color: blue;"&gt;&lt;strong&gt;&lt;img src="{{context_path}}/20260409211622222V6M/mceclip0.png" width="869" height="343"&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;img src="{{context_path}}/20260409211622222V6M/mceclip1.png" width="745" height="351"&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p style="text-align: justify; color: blue;"&gt;&lt;strong&gt;Ten en cuenta que solo permite 100 archivos cada vez, mi recomendación es que cuando subas una carpeta pulses &lt;img src="{{context_path}}/20260409211622222V6M/mceclip34.png"&gt; y empieces de nuevo. Tras hacer commit te lleva a esta pantalla, para seguir con la subida de archivos pulsa &lt;img src="{{context_path}}/20260409211622222V6M/mceclip36.png"&gt; y después &lt;img src="{{context_path}}/20260409211622222V6M/mceclip37.png"&gt;, te llevará a la pantalla de subida de archivos. Ve repitiendo la operación hasta que los tengas todos.&lt;/strong&gt;&lt;/p&gt;
&lt;p style="color: blue;"&gt;&lt;strong&gt;&lt;img src="{{context_path}}/20260409211622222V6M/mceclip35.png" style="display: block; margin-left: auto; margin-right: auto;"&gt;&lt;/strong&gt;&lt;/p&gt;
&lt;p style="color: blue;"&gt;&lt;strong&gt;&lt;/strong&gt;&lt;br&gt;&lt;/p&gt;
&lt;p style="color: blue;"&gt;&lt;strong&gt;No olvides ir pulsando&amp;nbsp; &lt;img src="{{context_path}}/20260409211622222V6M/mceclip39.png"&gt; &amp;nbsp; al final de la pantalla tras la subida de cada archivo o carpeta.&lt;/strong&gt;&lt;/p&gt;
&lt;p style="text-align: justify; color: blue;"&gt;&lt;strong&gt;&lt;/strong&gt;&lt;br&gt;&lt;/p&gt;
&lt;p style="text-align: justify; color: blue;"&gt;&lt;strong&gt;Cuando hayas terminado la subida, comprueba que el fichero&lt;strong&gt; index.html&lt;/strong&gt; esté subido. En GitHub se verá así:&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src="{{context_path}}/20260409211622222V6M/mceclip38.png" style="display: block; margin-left: auto; margin-right: auto;"&gt;&lt;/p&gt;
&lt;p&gt;&lt;br&gt;&lt;/p&gt;
&lt;p style="text-align: justify; color: blue;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p class="clearfix"&gt;&lt;/p&gt;&lt;/div&gt;
            &lt;/div&gt;&lt;/div&gt;&lt;/div&gt;</htmlView><jsonProperties>{"ideviceId":"20260409211622222V6M","textInfoDurationInput":"","textInfoDurationTextInput":"Duración","textInfoParticipantsInput":"","textInfoParticipantsTextInput":"Agrupamiento","textTextarea":"&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;strong&gt;Ahora tenemos que subir nuestros archivos, para ello tienes que localizar la carpeta que exportaste desde eXeLearning desde siguiente pantalla:&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip11.png\" style=\"display: block; margin-left: auto; margin-right: auto;\" /&gt;&lt;/p&gt;\n&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;strong&gt;Muy importante, al subir hay que mantener la estructura de los ficheros, te recomiendo abrir el explorador de archivos de tu equipo y arrastrar archivos y carpetas directamente.&lt;/strong&gt;&lt;/p&gt;\n&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;strong&gt;&lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip0.png\" width=\"869\" height=\"343\" /&gt;                              &lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip1.png\" width=\"745\" height=\"351\" /&gt;&lt;/strong&gt;&lt;/p&gt;\n&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;strong&gt;Ten en cuenta que solo permite 100 archivos cada vez, mi recomendación es que cuando subas una carpeta pulses &lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip34.png\" /&gt; y empieces de nuevo. Tras hacer commit te lleva a esta pantalla, para seguir con la subida de archivos pulsa &lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip36.png\" /&gt; y después &lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip37.png\" /&gt;, te llevará a la pantalla de subida de archivos. Ve repitiendo la operación hasta que los tengas todos.&lt;/strong&gt;&lt;/p&gt;\n&lt;p style=\"color: blue;\"&gt;&lt;strong&gt;&lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip35.png\" style=\"display: block; margin-left: auto; margin-right: auto;\" /&gt;&lt;/strong&gt;&lt;/p&gt;\n&lt;p style=\"color: blue;\"&gt;&lt;strong&gt;&lt;/strong&gt;&lt;br /&gt;&lt;/p&gt;\n&lt;p style=\"color: blue;\"&gt;&lt;strong&gt;No olvides ir pulsando  &lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip39.png\" /&gt;   al final de la pantalla tras la subida de cada archivo o carpeta.&lt;/strong&gt;&lt;/p&gt;\n&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;strong&gt;&lt;/strong&gt;&lt;br /&gt;&lt;/p&gt;\n&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;strong&gt;Cuando hayas terminado la subida, comprueba que el fichero&lt;strong&gt; index.html&lt;/strong&gt; esté subido. En GitHub se verá así:&lt;/strong&gt;&lt;/p&gt;\n&lt;p&gt;&lt;img src=\"{{context_path}}/20260409211622222V6M/mceclip38.png\" style=\"display: block; margin-left: auto; margin-right: auto;\" /&gt;&lt;/p&gt;\n&lt;p&gt;&lt;br /&gt;&lt;/p&gt;\n&lt;p style=\"text-align: justify; color: blue;\"&gt;&lt;br /&gt;&lt;/p&gt;","textFeedbackInput":"Mostrar retroalimentación","textFeedbackTextarea":""}</jsonProperties><odeComponentsOrder>1</odeComponentsOrder><odeComponentsProperties><odeComponentsProperty><key>visibility</key><value>true</value></odeComponentsProperty><odeComponentsProperty><key>teacherOnly</key><value>false</value></odeComponentsProperty><odeComponentsProperty><key>identifier</key><value/></odeComponentsProperty><odeComponentsProperty><key>cssClass</key><value/></odeComponentsProperty></odeComponentsProperties></odeComponent></odeComponents></odePagStructure></odePagStructures></odeNavStructure><odeNavStructure><odePageId>20260410054007DJQDBM</odePageId><odeParentPageId/><pageName>Preparar el enlace publicado de tu proyecto</pageName><odeNavStructureOrder>5</odeNavStructureOrder><odeNavStructureProperties><odeNavStructureProperty><key>titleNode</key><value>Preparar el enlace publicado de tu proyecto</value></odeNavStructureProperty><odeNavStru